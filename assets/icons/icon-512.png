<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="iconGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#007AFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0051D5;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo redondeado -->
  <rect x="0" y="0" width="512" height="512" rx="100" fill="url(#iconGrad2)"/>
  
  <!-- Icono de check + lista -->
  <circle cx="256" cy="256" r="160" fill="white" opacity="0.95"/>
  
  <!-- Líneas de lista -->
  <line x1="130" y1="200" x2="380" y2="200" stroke="#007AFF" stroke-width="20" stroke-linecap="round"/>
  <line x1="130" y1="280" x2="380" y2="280" stroke="#007AFF" stroke-width="20" stroke-linecap="round" opacity="0.6"/>
  <line x1="130" y1="360" x2="270" y2="360" stroke="#007AFF" stroke-width="20" stroke-linecap="round" opacity="0.4"/>
  
  <!-- Checkmark -->
  <path d="M 310 340 L 355 385 L 420 310" stroke="#34C759" stroke-width="18" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
</svg>