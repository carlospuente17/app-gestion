<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192">
  <defs>
    <linearGradient id="iconGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#007AFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0051D5;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fondo redondeado -->
  <rect x="0" y="0" width="192" height="192" rx="40" fill="url(#iconGrad1)"/>
  
  <!-- Icono de check + lista -->
  <circle cx="96" cy="96" r="60" fill="white" opacity="0.95"/>
  
  <!-- Líneas de lista -->
  <line x1="50" y1="75" x2="142" y2="75" stroke="#007AFF" stroke-width="6" stroke-linecap="round"/>
  <line x1="50" y1="105" x2="142" y2="105" stroke="#007AFF" stroke-width="6" stroke-linecap="round" opacity="0.6"/>
  <line x1="50" y1="135" x2="100" y2="135" stroke="#007AFF" stroke-width="6" stroke-linecap="round" opacity="0.4"/>
  
  <!-- Checkmark -->
  <path d="M 110 125 L 125 140 L 155 105" stroke="#34C759" stroke-width="7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
</svg>